# Cloudflare DDNS Environment Variables

# Cloudflare account email address
CF_EMAIL=your-email@example.com

# Cloudflare API token (with DNS edit permissions)
CF_API_TOKEN=your-api-token-here

# Cloudflare Zone ID for the domain
CF_ZONE_ID=your-zone-id-here

# DNS record name to update (e.g., home.example.com)
CF_RECORD_NAME=home.example.com

# Timezone for the container
TZ=America/Toronto

# Interval in seconds to check for IP changes
CHECK_INTERVAL=300
