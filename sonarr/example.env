# Sonarr Environment Variables

# PostgreSQL password for the database
POSTGRES_PASSWORD=your-secure-password-here

# User ID for file permissions
PUID=1000

# Group ID for file permissions
PGID=1000

# Timezone for the container
TZ=America/Toronto

# Host path for PostgreSQL data directory
POSTGRES_DATA_PATH=/mnt/docker/stacks/sonarr/postgres/data

# Host path for PostgreSQL init SQL script
POSTGRES_INIT_PATH=/mnt/docker/stacks/sonarr/postgres/init-sonarr.sql

# Host path for Sonarr configuration directory
SONARR_CONFIG_PATH=/mnt/docker/stacks/sonarr/sonarr

# Host path for media library
MEDIA_PATH=/mnt/Media
