# Watchtower Environment Variables

# Timezone (required so WATCHTOWER_SCHEDULE uses local time instead of UTC)
TZ=America/Toronto

# 6-field Spring cron: seconds minutes hours day month weekday
# This example runs daily at 3:00 AM
WATCHTOWER_SCHEDULE=0 0 3 * * *

# Label shown in notifications instead of the container ID
WATCHTOWER_NOTIFICATIONS_HOSTNAME=my-server

# Pushover via Shoutrrr
# Syntax: pushover://:<app-api-token>@<user-key>?devices=<device-name>
# - App API token: create an application at https://pushover.net/apps/build
# - User key: shown on your Pushover dashboard
# - devices: your Pushover device name (omitting it may silently fail)
WATCHTOWER_NOTIFICATION_URL=pushover://:<app-api-token>@<user-key>?devices=<device-name>
