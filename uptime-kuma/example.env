# Uptime Kuma Environment Variables

# Timezone for the container
TZ=America/Toronto

# External MariaDB hostname or IP
DB_HOSTNAME=your-db-host-here

# MariaDB port
DB_PORT=3306

# MariaDB database name
DB_NAME=uptime_kuma

# MariaDB username
DB_USERNAME=uptime_kuma

# MariaDB password
DB_PASSWORD=your-secure-password-here
